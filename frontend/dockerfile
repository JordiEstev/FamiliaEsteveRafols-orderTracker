# ---- build stage ----
FROM node:20-alpine AS builder
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
RUN npm run build                # ➜ static files in /app/dist

# ---- runtime stage ----
FROM nginx:1.27-alpine
COPY --from=builder /app/dist /usr/share/nginx/html
# tell nginx to listen on 80 by default
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
