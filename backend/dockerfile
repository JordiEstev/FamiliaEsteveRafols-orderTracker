# ---- build image ----
FROM python:3.11-slim

# 1. set workdir
WORKDIR /app

# 2. install deps
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# 3. copy source
COPY . .

# 4. expose port and run
EXPOSE 8000
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]
