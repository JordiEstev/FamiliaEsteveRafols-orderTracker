{
  "name": "familia-esteve-ordertracker",
  "private": true,

  /* 1️⃣  Any time someone runs  npm install  at the repo root,
         immediately run  npm install  inside ./frontend as well */
  "scripts": {
    "postinstall": "npm --prefix frontend install",

    /* Dev server for local hacking: npm run dev */
    "dev": "npm --prefix frontend run dev",

    /* Production build that Vercel will call */
    "build": "npm --prefix frontend run build",

    /* Optional: vite preview after building */
    "preview": "npm --prefix frontend run preview"
  }
}
